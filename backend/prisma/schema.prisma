datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id            String             @id @default(uuid())
  name          String
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  users         User[]
  projects      Project[]
  templates     WorkflowTemplate[]
  executions    Workflow[]
  apiKeys       ApiKey[]
  jobs          Job[]
  notifications Notification[]
  schedules     WorkflowSchedule[]
  webhooks      Webhook[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

model Project {
  id          String             @id @default(uuid())
  name        String
  tenantId    String             @map("tenant_id")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templates   WorkflowTemplate[]
  executions  Workflow[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("projects")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          String         @default("USER")
  isVerified    Boolean        @default(false)
  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  jobs          Job[]
  workflows     Workflow[]
  notifications Notification[]
  tenantId      String?        @map("tenant_id")
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Job {
  id           String        @id @default(uuid())
  title        String
  description  String?
  type         String
  status       JobStatus     @default(PENDING)
  priority     JobPriority   @default(MEDIUM)
  payload      Json
  result       Json?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowStep WorkflowStep?
  tenantId     String?       @map("tenant_id")
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("jobs")
}

enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model WorkflowTemplate {
  id          String            @id @default(uuid())
  name        String
  description String?
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId   String?           @map("project_id")
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  versions    WorkflowVersion[]
  schedules   WorkflowSchedule[]
  webhooks    Webhook[]

  @@map("workflow_templates")
}

model WorkflowVersion {
  id          String            @id @default(uuid())
  templateId  String            @map("template_id")
  template    WorkflowTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  dsl         Json              // Stores the JSON layout of steps
  isActive    Boolean           @default(false) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  executions  Workflow[]

  @@unique([templateId, version])
  @@map("workflow_versions")
}

model Workflow {
  id              String            @id @default(uuid())
  name            String
  status          WorkflowStatus    @default(PENDING)
  currentStep     String?           @map("current_step")
  progress        Float             @default(0.0)
  userId          String            @map("user_id")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  steps           WorkflowStep[]
  histories       WorkflowHistory[]
  tenantId        String?           @map("tenant_id")
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId       String?           @map("project_id")
  project         Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId       String?           @map("version_id")
  version         WorkflowVersion?  @relation(fields: [versionId], references: [id], onDelete: SetNull)
  triggerType     String            @default("MANUAL") @map("trigger_type")
  triggerMetadata Json?             @map("trigger_metadata")

  @@map("workflows")
}

model WorkflowStep {
  id          String         @id @default(uuid())
  workflowId  String         @map("workflow_id")
  workflow    Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId      String         @map("step_id")
  stepNumber  Int            @map("step_number")
  jobType     String         @map("job_type")
  status      WorkflowStatus @default(PENDING)
  priority    JobPriority    @default(MEDIUM)
  payload     Json
  dependsOn   Json
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  jobId       String?        @unique @map("job_id")
  job         Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([workflowId, stepId])
  @@map("workflow_steps")
}

model WorkflowHistory {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId      String?  @map("step_id")
  event       String
  message     String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("workflow_histories")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  hashedKey   String    @unique @map("hashed_key")
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

model WorkflowSchedule {
  id          String           @id @default(uuid())
  name        String
  cron        String
  isActive    Boolean          @default(true) @map("is_active")
  templateId  String           @map("template_id")
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tenantId    String           @map("tenant_id")
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("workflow_schedules")
}

model Webhook {
  id          String            @id @default(uuid())
  name        String
  url         String?
  events      Json?
  secret      String?
  type        String            @default("OUTBOUND")
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId  String?           @map("template_id")
  template    WorkflowTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("webhooks")
}

enum NotificationType {
  SUCCESS
  WARNING
  ERROR
  INFO
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  tenantId  String?          @map("tenant_id")
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  tenantId  String?  @map("tenant_id")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
