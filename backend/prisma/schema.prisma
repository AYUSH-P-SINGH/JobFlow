datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Tenant {
  id            String             @id @default(uuid())
  name          String
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  users         User[]
  projects      Project[]
  templates     WorkflowTemplate[]
  executions    Workflow[]
  apiKeys       ApiKey[]
  jobs          Job[]
  notifications Notification[]
  schedules     WorkflowSchedule[]
  webhooks      Webhook[]
  auditLogs     AuditLog[]
  policies      Policy[]
  quota         TenantQuota?

  @@map("tenants")
}

model Project {
  id          String             @id @default(uuid())
  name        String
  tenantId    String             @map("tenant_id")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templates   WorkflowTemplate[]
  executions  Workflow[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("projects")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          String         @default("USER")
  isVerified    Boolean        @default(false)
  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  jobs          Job[]
  workflows     Workflow[]
  notifications Notification[]
  tenantId      String?        @map("tenant_id")
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Job {
  id           String        @id @default(uuid())
  title        String
  description  String?
  type         String
  status       JobStatus     @default(PENDING)
  priority     JobPriority   @default(MEDIUM)
  payload      Json
  result       Json?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowStep WorkflowStep?
  tenantId     String?       @map("tenant_id")
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("jobs")
  @@index([status])
  @@index([tenantId])
  @@index([type])
}

enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model WorkflowTemplate {
  id          String            @id @default(uuid())
  name        String
  description String?
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId   String?           @map("project_id")
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  versions    WorkflowVersion[]
  schedules   WorkflowSchedule[]
  webhooks    Webhook[]

  @@map("workflow_templates")
}

model WorkflowVersion {
  id          String            @id @default(uuid())
  templateId  String            @map("template_id")
  template    WorkflowTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  dsl         Json              // Stores the JSON layout of steps
  isActive    Boolean           @default(false) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  executions  Workflow[]

  @@unique([templateId, version])
  @@map("workflow_versions")
}

model Workflow {
  id              String            @id @default(uuid())
  name            String
  status          WorkflowStatus    @default(PENDING)
  currentStep     String?           @map("current_step")
  progress        Float             @default(0.0)
  userId          String            @map("user_id")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  steps           WorkflowStep[]
  histories       WorkflowHistory[]
  tenantId        String?           @map("tenant_id")
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId       String?           @map("project_id")
  project         Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId       String?           @map("version_id")
  version         WorkflowVersion?  @relation(fields: [versionId], references: [id], onDelete: SetNull)
  triggerType     String            @default("MANUAL") @map("trigger_type")
  triggerMetadata Json?             @map("trigger_metadata")
  checkpoints     WorkflowCheckpoint[]
  recoveryLogs    RecoveryLog[]

  @@map("workflows")
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
}

model WorkflowStep {
  id          String         @id @default(uuid())
  workflowId  String         @map("workflow_id")
  workflow    Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId      String         @map("step_id")
  stepNumber  Int            @map("step_number")
  jobType     String         @map("job_type")
  status      WorkflowStatus @default(PENDING)
  priority    JobPriority    @default(MEDIUM)
  payload     Json
  dependsOn   Json
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  jobId       String?        @unique @map("job_id")
  job         Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([workflowId, stepId])
  @@map("workflow_steps")
  @@index([status])
  @@index([workflowId])
}

model WorkflowHistory {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId      String?  @map("step_id")
  event       String
  message     String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("workflow_histories")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  hashedKey   String    @unique @map("hashed_key")
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

model WorkflowSchedule {
  id          String           @id @default(uuid())
  name        String
  cron        String
  isActive    Boolean          @default(true) @map("is_active")
  templateId  String           @map("template_id")
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tenantId    String           @map("tenant_id")
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("workflow_schedules")
}

model Webhook {
  id          String            @id @default(uuid())
  name        String
  url         String?
  events      Json?
  secret      String?
  type        String            @default("OUTBOUND")
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId  String?           @map("template_id")
  template    WorkflowTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("webhooks")
}

enum NotificationType {
  SUCCESS
  WARNING
  ERROR
  INFO
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  tenantId  String?          @map("tenant_id")
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  tenantId  String?  @map("tenant_id")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model DeadLetterJob {
  id           String    @id @default(uuid())
  jobId        String    @unique @map("job_id")
  queueName    String    @map("queue_name")
  payload      Json
  error        Json?
  attemptsMade Int       @map("attempts_made")
  failedAt     DateTime  @default(now()) @map("failed_at")
  status       String    @default("FAILED") // FAILED, REPLAYED, DISCARDED
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("dead_letter_jobs")
}

model WorkflowCheckpoint {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  stepId      String   @map("step_id")
  stepNumber  Int      @map("step_number")
  status      String   @map("status")
  result      Json?    @map("result")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepId])
  @@map("workflow_checkpoints")
}

model Policy {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  rules       Json     // e.g. { maxRuntime, allowedJobTypes, restrictedUsers, businessHours }
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenantId    String?  @map("tenant_id")
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("policies")
}

model TenantQuota {
  id                  String   @id @default(uuid())
  tenantId            String   @unique @map("tenant_id")
  maxWorkflowsPerDay  Int      @default(100) @map("max_workflows_per_day")
  maxConcurrent       Int      @default(20) @map("max_concurrent_workflows")
  maxApiCallsPerMonth Int      @default(10000) @map("max_api_calls_per_month")
  retentionDays       Int      @default(90) @map("retention_days")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_quotas")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  rules       Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model RecoveryLog {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  stepId      String?  @map("step_id")
  action      String   // RESUMED, RESET
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("recovery_logs")
}

// ─── Phase 16: Intelligent Worker Management ────────────────────────────────

enum WorkerStatus {
  STARTING
  READY
  BUSY
  DRAINING
  OFFLINE
}

model WorkerNode {
  id              String       @id @default(uuid())
  hostname        String
  port            Int          @default(5001)
  status          WorkerStatus @default(STARTING)
  region          String       @default("default")
  tags            Json         @default("[]")
  cpu             Int          @default(1)
  memory          Int          @default(512)
  gpu             Boolean      @default(false)
  supportedJobs   Json         @default("[]") @map("supported_jobs")
  concurrency     Int          @default(5)
  runningJobs     Int          @default(0) @map("running_jobs")
  completedJobs   Int          @default(0) @map("completed_jobs")
  failedJobs      Int          @default(0) @map("failed_jobs")
  currentLoad     Float        @default(0.0) @map("current_load")
  lastHeartbeat   DateTime     @default(now()) @map("last_heartbeat")
  startedAt       DateTime     @default(now()) @map("started_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  queueName       String?      @map("queue_name")

  @@map("worker_nodes")
  @@index([status])
  @@index([lastHeartbeat])
}
